@using ColorPop.Core.Models
@using ColorPop.Core.Enums

<div class="board">
    <p>Session exists: @(Session is not null)</p>
<p>Board exists: @(Session?.State?.Board is not null)</p>
<p>Rows: @(Session?.State?.Board?.Rows)</p>
<p>Cols: @(Session?.State?.Board?.Cols)</p>
    @if (Session?.State?.Board is not null)
    {
        <table class="board-table">
            @for (int r = 0; r < Session.State.Board.Rows; r++)
            {
                <tr>
                    @for (int c = 0; c < Session.State.Board.Cols; c++)
                    {
                        var pos = new Position(r, c);
                        var token = Session.State.Board.GetToken(pos);

                        <td class="cell @GetCellClass(token)"
                            @onclick="() => OnCellClicked(pos)">
                        </td>
                    }
                </tr>
            }
        </table>
    }
</div>

